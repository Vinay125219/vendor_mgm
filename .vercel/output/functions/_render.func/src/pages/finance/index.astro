---
import VendorShell from '@/layouts/VendorShell.astro';
import PageHeader from '@/components/ui/PageHeader.astro';
import KpiCard from '@/components/ui/KpiCard.astro';
import UiCard from '@/components/ui/UiCard.astro';
import UiButton from '@/components/ui/UiButton.astro';
import UiBadge from '@/components/ui/UiBadge.astro';
import ChartBlock from '@/components/islands/ChartBlock.astro';
import {
  getDashboardKpis,
  getPaymentStatusDistribution,
  getFulfillmentTrends,
} from '@/services/dashboard.service';
import { formatINRFromPaise, formatDate } from '@/lib/format';

const kpis = getDashboardKpis();
const payDist = getPaymentStatusDistribution();
const fulfill = getFulfillmentTrends();

const paySpec = {
  type: 'doughnut' as const,
  labels: payDist.map((p) => p.status),
  datasets: [
    {
      label: 'Payment Status',
      data: payDist.map((p) => p.count),
      backgroundColor: ['#22c55e', '#eab308', '#ef4444', '#6366f1', '#94a3b8'],
    },
  ],
};

const settlementSpec = {
  type: 'bar' as const,
  labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
  datasets: [
    {
      label: 'Daily Settlements (₹)',
      data: [245000, 189000, 312000, 156000, 428000, 198000, 267000],
      backgroundColor: 'rgba(34, 197, 94, 0.7)',
    },
  ],
};
---

<VendorShell title="Finance Operations">
  <PageHeader
    title="Financial operations center"
    description="Payment processing, settlements, reconciliation — complete financial oversight and reporting."
  >
    <UiButton href="#settlements" variant="primary" slot="actions">Process settlements</UiButton>
    <UiButton href="#reconciliation" variant="secondary" slot="actions">Reconciliation</UiButton>
  </PageHeader>

  <!-- Financial KPIs -->
  <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <KpiCard 
      label="Total payments captured" 
      value={formatINRFromPaise(kpis.grossRevenuePaise)} 
      trend="+18% vs last month"
      trendUp 
    />
    <KpiCard 
      label="Pending settlements" 
      value={formatINRFromPaise(Math.floor(kpis.grossRevenuePaise * 0.15))} 
      hint="Next cycle: 2 days"
    />
    <KpiCard 
      label="Settled (MTD)" 
      value={formatINRFromPaise(Math.floor(kpis.grossRevenuePaise * 0.85))} 
      trend="98.2% success"
      trendUp
    />
    <KpiCard 
      label="Failed/refunded" 
      value={formatINRFromPaise(Math.floor(kpis.grossRevenuePaise * 0.03))} 
      hint="Initiated refunds"
    />

    <KpiCard label="Settlement success rate" value="99.8%" hint="Industry leading" trendUp />
    <KpiCard label="Avg settlement time" value="2.1 days" hint="Faster than avg" trendUp />
    <KpiCard label="Reconciliation status" value="100%" hint="Fully reconciled" trendUp />
    <KpiCard label="Chargeback rate" value="0.08%" hint="Very low risk" trendUp />
  </section>

  <!-- Payment & Settlement Overview -->
  <div class="mt-8 grid gap-6 lg:grid-cols-2">
    <UiCard padding="lg">
      <h2 class="mb-4 text-lg font-semibold">Payment Status Distribution</h2>
      <ChartBlock spec={paySpec} />
    </UiCard>

    <UiCard padding="lg">
      <h2 class="mb-4 text-lg font-semibold">Daily Settlement Volume (Last 7 days)</h2>
      <ChartBlock spec={settlementSpec} />
    </UiCard>
  </div>

  <!-- Active Settlements -->
  <div class="mt-8 grid gap-6">
    <UiCard padding="lg">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-semibold">Pending Settlement Batches</h2>
        <UiBadge variant="warning">8 Pending</UiBadge>
      </div>
      <div class="space-y-3">
        {Array.from({ length: 5 }).map((_, i) => (
          <div class="flex items-center justify-between rounded-lg border border-amber-500/20 bg-amber-500/5 px-3 py-3">
            <div class="flex-1">
              <p class="font-medium">Settlement Batch #{i + 1001}</p>
              <p class="text-xs text-vs-muted">{formatINRFromPaise((i + 1) * 150000)} • {['2 hours', '4 hours', '1 day', '2 days', '3 days'][i]}</p>
            </div>
            <div class="flex gap-2">
              <UiButton variant="secondary" size="sm">Review</UiButton>
              <UiButton variant="primary" size="sm">Process</UiButton>
            </div>
          </div>
        ))}
      </div>
    </UiCard>

    <!-- Refund Processing -->
    <UiCard padding="lg">
      <h2 class="mb-4 text-lg font-semibold">Active Refund Processing</h2>
      <div class="space-y-3">
        {['Customer refund request - Order #45821', 'Payment reversal - Duplicate charge', 'Chargeback - Customer dispute', 'Partial refund - Item return', 'Cancelled order - Auto refund'].map((refund, i) => (
          <div class="flex items-center justify-between border-b border-vs-border py-3 last:border-b-0">
            <div>
              <p class="font-medium">{refund}</p>
              <p class="text-xs text-vs-muted">{formatINRFromPaise((i + 1) * 5000)} • {formatDate(new Date(Date.now() - i * 3600000).toISOString())}</p>
            </div>
            <UiBadge variant={i === 0 ? 'danger' : 'warning'}>
              {['URGENT', 'HIGH', 'MEDIUM', 'LOW', 'PENDING'][i]}
            </UiBadge>
          </div>
        ))}
      </div>
    </UiCard>

    <!-- Daily Reconciliation -->
    <UiCard padding="lg">
      <h2 class="mb-4 text-lg font-semibold">Daily Reconciliation Status</h2>
      <div class="space-y-2">
        {[
          { date: 'Today', status: 'In Progress', matched: '99.8%' },
          { date: 'Yesterday', status: 'Completed', matched: '100%' },
          { date: '2 days ago', status: 'Completed', matched: '100%' },
          { date: '3 days ago', status: 'Completed', matched: '99.9%' },
        ].map((rec) => (
          <div class="flex items-center justify-between border-b border-vs-border py-2 last:border-b-0">
            <div>
              <p class="font-medium">{rec.date}</p>
              <p class="text-xs text-vs-muted">{rec.matched} matched</p>
            </div>
            <UiBadge variant={rec.status === 'Completed' ? 'success' : 'info'}>
              {rec.status}
            </UiBadge>
          </div>
        ))}
      </div>
    </UiCard>
  </div>
</VendorShell>
