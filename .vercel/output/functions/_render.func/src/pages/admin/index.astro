---
import VendorShell from '@/layouts/VendorShell.astro';
import PageHeader from '@/components/ui/PageHeader.astro';
import KpiCard from '@/components/ui/KpiCard.astro';
import UiCard from '@/components/ui/UiCard.astro';
import UiButton from '@/components/ui/UiButton.astro';
import UiBadge from '@/components/ui/UiBadge.astro';
import ChartBlock from '@/components/islands/ChartBlock.astro';
import {
  getDashboardKpis,
  getVendorGrowthSeries,
  getPaymentStatusDistribution,
} from '@/services/dashboard.service';
import { formatDate, formatINRFromPaise } from '@/lib/format';

const kpis = getDashboardKpis();
const growth = getVendorGrowthSeries(5);
const payDist = getPaymentStatusDistribution();

const growthSpec = {
  type: 'line' as const,
  labels: growth.map((g) => g.date),
  datasets: [
    {
      label: 'Active vendors',
      data: growth.map((g) => g.value),
      borderColor: 'rgb(99, 102, 241)',
      backgroundColor: 'rgba(99, 102, 241, 0.12)',
    },
  ],
};

const complianceSpec = {
  type: 'bar' as const,
  labels: ['KYC Verified', 'Pending Review', 'Failed', 'Rejected'],
  datasets: [
    {
      label: 'Vendor Status',
      data: [85, 12, 3, 2],
      backgroundColor: ['#22c55e', '#f59e0b', '#ef4444', '#94a3b8'],
    },
  ],
};
---

<VendorShell title="Platform Administration">
  <PageHeader
    title="Platform control center"
    description="Manage vendors, monitor compliance, track platform health — full administrative control."
  >
    <UiButton href="#vendor-list" variant="primary" slot="actions">Manage vendors</UiButton>
    <UiButton href="#compliance" variant="secondary" slot="actions">Compliance review</UiButton>
  </PageHeader>

  <!-- Key Metrics -->
  <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <KpiCard label="Total vendors" value={String(kpis.totalVendors)} trend="+4 this month" trendUp />
    <KpiCard label="Pending approvals" value={String(kpis.pendingApprovals)} hint="Requires action" />
    <KpiCard label="Suspended vendors" value={String(Math.floor(kpis.totalVendors * 0.05))} hint="Risk management" />
    <KpiCard label="Active vendors" value={String(kpis.activeVendors)} hint="KYC verified & trading" trendUp />

    <KpiCard label="Gross revenue" value={formatINRFromPaise(kpis.grossRevenuePaise)} trend="+8% growth" trendUp />
    <KpiCard label="Open disputes" value={String(kpis.openDisputes)} hint="Escalated cases" />
    <KpiCard label="System health" value="99.8%" hint="Uptime this month" trendUp />
    <KpiCard label="Completed orders" value={String(kpis.completedOrders)} hint="Platform volume" />
  </section>

  <!-- Vendor Management & Compliance -->
  <div class="mt-8 grid gap-6 lg:grid-cols-2">
    <UiCard padding="lg">
      <h2 class="mb-4 text-lg font-semibold">Vendor Growth</h2>
      <ChartBlock spec={growthSpec} />
    </UiCard>

    <UiCard padding="lg">
      <h2 class="mb-4 text-lg font-semibold">Vendor Compliance Status</h2>
      <ChartBlock spec={complianceSpec} />
    </UiCard>
  </div>

  <!-- Pending Actions -->
  <div class="mt-8 grid gap-6">
    <UiCard padding="lg" id="vendor-list">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-semibold">Vendors Pending Approval</h2>
        <UiBadge variant="warning">{kpis.pendingApprovals} Pending</UiBadge>
      </div>
      <div class="space-y-3">
        {Array.from({ length: 5 }).map((_, i) => (
          <div class="flex items-center justify-between rounded-lg border border-amber-500/20 bg-amber-500/5 px-3 py-3">
            <div>
              <p class="font-medium">Vendor {i + 1}</p>
              <p class="text-xs text-vs-muted">GSTIN: 18AABCU{String(1234 + i).padStart(4, '0')}H1Z0</p>
            </div>
            <div class="flex gap-2">
              <UiButton variant="secondary" size="sm">Review</UiButton>
              <UiButton variant="primary" size="sm">Approve</UiButton>
            </div>
          </div>
        ))}
      </div>
    </UiCard>

    <!-- Compliance Alerts -->
    <UiCard padding="lg" id="compliance">
      <h2 class="mb-4 text-lg font-semibold">Compliance Alerts & Actions</h2>
      <div class="space-y-3">
        {['High GMV vendor - verify KYC', 'Duplicate vendor registration detected', 'Unusual payment pattern flagged', 'Vendor suspension review due'].map((alert, i) => (
          <div class="flex items-center justify-between border-b border-vs-border py-3 last:border-b-0">
            <div>
              <p class="font-medium">{alert}</p>
              <p class="text-xs text-vs-muted">{formatDate(Date.now() - i * 3600000)}</p>
            </div>
            <UiBadge variant={i === 0 ? 'error' : 'warning'}>
              {['CRITICAL', 'HIGH', 'MEDIUM', 'LOW'][i]}
            </UiBadge>
          </div>
        ))}
      </div>
    </UiCard>
  </div>
</VendorShell>
