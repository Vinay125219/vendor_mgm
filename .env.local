# Backend Configuration
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_EXPIRATION=86400
BCRYPT_ROUNDS=10

# Razorpay — use test keys in development; never commit live secrets.
PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxx

# Optional: Database URL for production
# DATABASE_URL=postgresql://user:password@localhost:5432/vendorsphere

# Optional: Redis URL for caching
# REDIS_URL=redis://localhost:6379
