---
interface Props {
  label: string;
  value: string;
  hint?: string;
  trend?: string;
  trendUp?: boolean;
  class?: string;
}

const { label, value, hint, trend, trendUp, class: className = '' } = Astro.props;
---

<div
  class:list={[
    'vs-card flex flex-col gap-1 border-vs-border/80 p-5 transition-transform duration-300 hover:-translate-y-0.5',
    className,
  ]}
>
  <p class="text-xs font-semibold uppercase tracking-wider text-vs-muted">{label}</p>
  <p class="text-2xl font-bold tabular-nums tracking-tight text-vs-fg">{value}</p>
  {hint && <p class="text-xs text-vs-muted">{hint}</p>}
  {
    trend && (
      <p
        class:list={[
          'text-xs font-medium',
          trendUp ? 'text-emerald-600 dark:text-emerald-400' : 'text-vs-muted',
        ]}
      >
        {trend}
      </p>
    )
  }
</div>
