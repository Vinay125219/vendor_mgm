---
interface Props {
  class?: string;
  padding?: 'none' | 'sm' | 'md' | 'lg';
  hover?: boolean;
}

const { class: className = '', padding = 'md', hover = false } = Astro.props;

const pad: Record<string, string> = {
  none: '',
  sm: 'p-4',
  md: 'p-5 sm:p-6',
  lg: 'p-6 sm:p-8',
};
---

<div
  class:list={[
    'vs-card vs-animate-in',
    pad[padding],
    hover && 'transition-shadow duration-300 hover:shadow-[var(--shadow-vs-lg)]',
    className,
  ]}
>
  <slot />
</div>
