---
interface Props {
  id: string;
  title: string;
  message: string;
  confirmLabel?: string;
}

const { id, title, message, confirmLabel = 'Confirm' } = Astro.props;
---

<dialog
  id={id}
  class="w-[min(100%,420px)] rounded-[var(--radius-vs)] border border-vs-border bg-vs-surface p-0 text-vs-fg shadow-[var(--shadow-vs-lg)] backdrop:bg-black/40 open:animate-[vs-fade-in_0.2s_ease-out]"
  aria-labelledby={`${id}-title`}
>
  <form method="dialog" class="flex flex-col gap-4 p-6">
    <h2 id={`${id}-title`} class="text-lg font-semibold">
      {title}
    </h2>
    <p class="text-sm text-vs-muted">{message}</p>
    <div class="flex justify-end gap-2 pt-2">
      <button
        type="submit"
        value="cancel"
        class="rounded-[var(--radius-vs-sm)] border border-vs-border px-4 py-2 text-sm font-semibold hover:bg-vs-elevated"
      >
        Cancel
      </button>
      <button
        type="submit"
        value="confirm"
        class="rounded-[var(--radius-vs-sm)] bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700"
      >
        {confirmLabel}
      </button>
    </div>
  </form>
</dialog>
