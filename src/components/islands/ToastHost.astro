---

<div
  id="vs-toast-host"
  class="pointer-events-none fixed bottom-4 right-4 z-[100] flex max-w-sm flex-col gap-2"
  aria-live="polite"
/>

<script>
  type ToastLevel = 'info' | 'success' | 'warning' | 'error';

  function paint(level: ToastLevel) {
    const map: Record<ToastLevel, string> = {
      info: 'border-sky-500/40 bg-vs-surface text-vs-fg',
      success: 'border-emerald-500/40 bg-vs-surface text-vs-fg',
      warning: 'border-amber-500/40 bg-vs-surface text-vs-fg',
      error: 'border-red-500/40 bg-vs-surface text-vs-fg',
    };
    return map[level];
  }

  window.addEventListener('vs:toast', ((e: CustomEvent<{ message: string; level?: ToastLevel }>) => {
    const host = document.getElementById('vs-toast-host');
    if (!host) return;
    const level = e.detail.level ?? 'info';
    const el = document.createElement('div');
    el.className = `pointer-events-auto vs-animate-in rounded-[var(--radius-vs)] border px-4 py-3 text-sm shadow-[var(--shadow-vs-lg)] ${paint(level)}`;
    el.textContent = e.detail.message;
    host.appendChild(el);
    setTimeout(() => {
      el.classList.add('opacity-0', 'transition-opacity', 'duration-300');
      setTimeout(() => el.remove(), 320);
    }, 4200);
  }) as EventListener);
</script>
