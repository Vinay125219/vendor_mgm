---
---

<button
  type="button"
  class="flex h-10 w-10 items-center justify-center rounded-[var(--radius-vs-sm)] border border-vs-border bg-vs-surface text-vs-fg shadow-[var(--shadow-vs-sm)] transition hover:bg-vs-elevated"
  aria-label="Toggle color theme"
  data-theme-toggle
>
  <span class="dark:hidden" aria-hidden="true">◐</span>
  <span class="hidden dark:inline" aria-hidden="true">◑</span>
</button>

<script>
  const root = document.documentElement;

  function applyTheme(mode: 'light' | 'dark') {
    if (mode === 'dark') root.classList.add('dark');
    else root.classList.remove('dark');
    localStorage.setItem('vs-theme', mode);
  }

  function initTheme() {
    const saved = localStorage.getItem('vs-theme') as 'light' | 'dark' | null;
    if (saved === 'light' || saved === 'dark') {
      applyTheme(saved);
      return;
    }
    if (window.matchMedia('(prefers-color-scheme: dark)').matches) applyTheme('dark');
    else applyTheme('light');
  }

  initTheme();

  document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const next = root.classList.contains('dark') ? 'light' : 'dark';
      applyTheme(next);
      window.dispatchEvent(new CustomEvent('vs-theme', { detail: { mode: next } }));
    });
  });
</script>
