---
interface Props {
  spec: Record<string, unknown>;
  height?: number;
  class?: string;
}

const { spec, height = 220, class: className = '' } = Astro.props;
const specJson = JSON.stringify(spec);
---

<div class:list={['w-full', className]} data-vs-chart-root data-spec={specJson}>
  <div
    class="flex max-h-72 min-h-[var(--vs-chart-h,180px)] w-full items-center justify-center rounded-[var(--radius-vs-sm)] bg-vs-border/20 text-xs text-vs-muted dark:bg-vs-border/10"
    style={`--vs-chart-h:${height}px;min-height:${Math.min(height, 280)}px`}
    data-vs-chart-placeholder
    aria-hidden="true"
  >
    Chart loads when visible
  </div>
  <canvas
    class="hidden max-h-72 w-full"
    style={`max-height:${height}px`}
    data-vs-chart-canvas
    role="img"
    aria-label="Data chart"
  ></canvas>
</div>

<script>
  import type { Chart } from 'chart.js';

  type Spec = {
    type: 'line' | 'bar' | 'doughnut';
    labels: string[];
    datasets: { label: string; data: number[]; backgroundColor?: string[]; borderColor?: string }[];
  };

  const registry = new WeakMap<HTMLCanvasElement, Chart>();
  let chartModulePromise: Promise<typeof import('chart.js/auto')> | null = null;
  let activeObserver: IntersectionObserver | null = null;

  function getChartModule() {
    chartModulePromise ??= import('chart.js/auto');
    return chartModulePromise;
  }

  function readSpec(el: HTMLElement): Spec | null {
    const raw = el.getAttribute('data-spec');
    if (!raw) return null;
    try {
      return JSON.parse(raw) as Spec;
    } catch {
      return null;
    }
  }

  function applyDefaults(ChartCtor: (typeof import('chart.js/auto'))['default']) {
    const dark = document.documentElement.classList.contains('dark');
    ChartCtor.defaults.color = dark ? '#c4c8d4' : '#5c6170';
    ChartCtor.defaults.borderColor = dark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
    return dark;
  }

  function destroyRoot(root: HTMLElement) {
    const canvas = root.querySelector<HTMLCanvasElement>('[data-vs-chart-canvas]');
    const ph = root.querySelector<HTMLElement>('[data-vs-chart-placeholder]');
    if (canvas) {
      const ch = registry.get(canvas);
      ch?.destroy();
      registry.delete(canvas);
      canvas.classList.add('hidden');
    }
    ph?.classList.remove('hidden');
    root.removeAttribute('data-vs-chart-initialized');
  }

  async function initRoot(root: HTMLElement) {
    if (root.getAttribute('data-vs-chart-initialized')) return;
    const spec = readSpec(root);
    const canvas = root.querySelector<HTMLCanvasElement>('[data-vs-chart-canvas]');
    const ph = root.querySelector<HTMLElement>('[data-vs-chart-placeholder]');
    if (!spec || !canvas) return;

    const { default: ChartCtor } = await getChartModule();
    const dark = applyDefaults(ChartCtor);

    const chart = new ChartCtor(canvas, {
      type: spec.type,
      data: {
        labels: spec.labels,
        datasets: spec.datasets.map((d) => ({
          ...d,
          tension: spec.type === 'line' ? 0.35 : undefined,
          fill: spec.type === 'line' ? true : undefined,
        })),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: { duration: 400 },
        plugins: { legend: { position: 'bottom', labels: { boxWidth: 10 } } },
        scales:
          spec.type === 'doughnut'
            ? {}
            : {
                x: { grid: { display: false } },
                y: { grid: { color: dark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.04)' } },
              },
      },
    });

    registry.set(canvas, chart);
    root.setAttribute('data-vs-chart-initialized', '1');
    ph?.classList.add('hidden');
    canvas.classList.remove('hidden');
  }

  function disconnectObserver() {
    activeObserver?.disconnect();
    activeObserver = null;
  }

  function observeCharts() {
    disconnectObserver();
    const roots = document.querySelectorAll<HTMLElement>('[data-vs-chart-root]');

    if (!('IntersectionObserver' in window)) {
      void getChartModule().then(() => {
        roots.forEach((r) => void initRoot(r));
      });
      return;
    }

    activeObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const root = entry.target as HTMLElement;
          activeObserver?.unobserve(root);
          void getChartModule().then(() => initRoot(root));
        }
      },
      { rootMargin: '120px', threshold: 0.01 },
    );

    roots.forEach((root) => {
      if (root.getAttribute('data-vs-chart-initialized')) return;
      activeObserver?.observe(root);
    });
  }

  function scheduleWork() {
    const run = () => observeCharts();
    if ('requestIdleCallback' in window) {
      requestIdleCallback(run, { timeout: 2000 });
    } else {
      requestAnimationFrame(run);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', scheduleWork, { once: true });
  } else {
    scheduleWork();
  }

  window.addEventListener('vs-theme', () => {
    void (async () => {
      document.querySelectorAll<HTMLElement>('[data-vs-chart-root]').forEach((r) => destroyRoot(r));
      disconnectObserver();
      const { default: ChartCtor } = await getChartModule();
      applyDefaults(ChartCtor);
      observeCharts();
    })();
  });
</script>
