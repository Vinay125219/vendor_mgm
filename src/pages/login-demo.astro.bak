---
import '@/styles/global.css';
import { APP_NAME } from '@/lib/constants';
import { ROLE_LABELS } from '@/lib/rbac';
import type { UserRole } from '@/types';

const roleOrder: UserRole[] = ['super_admin', 'admin', 'finance', 'support', 'vendor'];
const roleOptions = roleOrder.map((id) => ({ id, label: ROLE_LABELS[id] }));
const defaultRole: UserRole = 'admin';
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap"
    />
    <title>Sign in · {APP_NAME}</title>
    <script is:inline>
      try {
        if (location.pathname === '/login' && localStorage.getItem('vs_auth_token')) {
          var q = new URLSearchParams(location.search).get('redirect') || '/vendor';
          location.replace(q);
        }
      } catch (_) {}
    </script>
  </head>
  <body class="min-h-full bg-vs-bg text-vs-fg antialiased">
    <div class="flex min-h-screen flex-col items-center justify-center px-4 py-12">
      <div class="mb-10 text-center">
        <div
          class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-[var(--radius-vs)] bg-vs-accent text-xl font-bold text-white shadow-[var(--shadow-vs-md)]"
        >
          VS
        </div>
        <h1 class="text-2xl font-bold tracking-tight">{APP_NAME}</h1>
        <p class="mt-1 text-sm text-vs-muted">Vendor operations — sign in to continue</p>
      </div>

      <div class="vs-card w-full max-w-md p-8 shadow-[var(--shadow-vs-lg)]">
        <form id="vs-login-form" class="flex flex-col gap-4">
          <div id="vs-login-error" class="hidden rounded-[var(--radius-vs-sm)] border border-red-500/40 bg-red-500/10 px-3 py-2 text-sm text-red-800 dark:text-red-200" role="alert"></div>

          <label class="flex flex-col gap-1.5 text-sm">
            <span class="font-medium text-vs-muted">Workspace role</span>
            <select
              name="role"
              id="vs-role-select"
              required
              class="rounded-[var(--radius-vs-sm)] border border-vs-border bg-vs-bg px-3 py-2.5 text-vs-fg outline-none ring-vs-accent/30 focus:border-vs-accent focus:ring-2"
            >
              {
                roleOptions.map((r) => (
                  <option value={r.id} selected={r.id === defaultRole}>
                    {r.label}
                  </option>
                ))
              }
            </select>
            <span class="text-[11px] leading-relaxed text-vs-muted">
              Choosing a role autofills that role’s demo email and password. The browser checks that they match — you cannot sign in as Vendor with an Admin email.
            </span>
          </label>

          <label class="flex flex-col gap-1.5 text-sm">
            <span class="font-medium text-vs-muted">Email</span>
            <input
              name="email"
              id="vs-email-input"
              type="email"
              autocomplete="username"
              required
              value={defaultAcc.email}
              class="rounded-[var(--radius-vs-sm)] border border-vs-border bg-vs-bg px-3 py-2.5 text-vs-fg outline-none ring-vs-accent/30 focus:border-vs-accent focus:ring-2"
            />
          </label>
          <label class="flex flex-col gap-1.5 text-sm">
            <span class="font-medium text-vs-muted">Password</span>
            <input
              name="password"
              id="vs-password-input"
              type="password"
              autocomplete="current-password"
              required
              value={DEMO_SHARED_PASSWORD}
              class="rounded-[var(--radius-vs-sm)] border border-vs-border bg-vs-bg px-3 py-2.5 text-vs-fg outline-none ring-vs-accent/30 focus:border-vs-accent focus:ring-2"
            />
          </label>

          <button
            type="submit"
            class="mt-2 rounded-[var(--radius-vs-sm)] bg-vs-accent py-3 text-sm font-semibold text-white shadow-[var(--shadow-vs-sm)] transition hover:brightness-110 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-vs-accent"
          >
            Sign in
          </button>
        </form>

        <div class="mt-6 rounded-[var(--radius-vs-sm)] border border-dashed border-vs-border bg-vs-elevated/50 px-4 py-3 text-xs text-vs-muted">
          <p class="font-semibold text-vs-fg">Demo accounts (linked to roles)</p>
          <p class="mt-2 text-[11px] leading-relaxed">
            Shared password for all: <span class="font-mono text-vs-fg">{DEMO_SHARED_PASSWORD}</span>
          </p>
          <div class="mt-3 max-h-40 overflow-y-auto rounded-[var(--radius-vs-sm)] border border-vs-border/60">
            <table class="w-full text-left text-[11px]">
              <thead class="sticky top-0 bg-vs-elevated font-semibold text-vs-muted">
                <tr>
                  <th class="px-2 py-1.5">Role</th>
                  <th class="px-2 py-1.5">Email</th>
                </tr>
              </thead>
              <tbody id="vs-demo-table-body">
                {
                  roleOrder.map((id) => (
                    <tr class="border-t border-vs-border/40 vs-demo-row" data-demo-role={id} data-demo-email={DEMO_ACCOUNTS_BY_ROLE[id].email}>
                      <td class="px-2 py-1.5 text-vs-fg">{ROLE_LABELS[id]}</td>
                      <td class="px-2 py-1.5 font-mono text-[10px] text-vs-fg">{DEMO_ACCOUNTS_BY_ROLE[id].email}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
          <p class="mt-3 text-[11px] leading-relaxed">
            RBAC reads the role stored in your browser at sign-in; each row above is the only valid email for that role with this demo password.
          </p>
        </div>
      </div>
    </div>

    <script define:vars={{ accountsPayload, sharedPassword: DEMO_SHARED_PASSWORD, defaultRole }}>
      const accounts = JSON.parse(accountsPayload);
      const roleSelect = document.getElementById('vs-role-select');
      const emailInput = document.getElementById('vs-email-input');
      const passInput = document.getElementById('vs-password-input');

      function highlightDemoRow(role) {
        document.querySelectorAll('.vs-demo-row').forEach((row) => {
          const r = row.getAttribute('data-demo-role');
          if (r === role) {
            row.classList.add('bg-vs-accent-soft', 'text-vs-accent');
          } else {
            row.classList.remove('bg-vs-accent-soft', 'text-vs-accent');
          }
        });
      }

      function applyRole(role) {
        const acc = accounts[role];
        if (!acc || !emailInput || !passInput) return;
        emailInput.value = acc.email;
        passInput.value = acc.password || sharedPassword;
        highlightDemoRow(role);
      }

      roleSelect?.addEventListener('change', () => {
        applyRole(roleSelect.value);
      });

      applyRole(roleSelect?.value || defaultRole);

      const params = new URLSearchParams(window.location.search);
      const redirectTo = params.get('redirect') || '/vendor';
      const form = document.getElementById('vs-login-form');
      const errEl = document.getElementById('vs-login-error');

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        errEl?.classList.add('hidden');
        const fd = new FormData(form);
        const email = String(fd.get('email') || '');
        const password = String(fd.get('password') || '');
        const role = String(fd.get('role') || '');
        const { login } = await import('@/lib/client-auth');
        const result = login(email, password, role);
        if (!result.ok) {
          if (errEl) {
            errEl.textContent = result.message || 'Sign-in failed';
            errEl.classList.remove('hidden');
          }
          return;
        }
        window.location.href = redirectTo;
      });
    </script>
  </body>
</html>
